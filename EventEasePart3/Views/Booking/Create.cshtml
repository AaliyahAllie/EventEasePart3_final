@model EventEasePart3.Models.Booking

@{
    ViewData["Title"] = "Book Venue";
}

<div class="card app-card p-4">
    <h2 class="mb-3">Book Venue</h2>
    <p class="text-muted">Venue: <strong>@ViewBag.VenueName</strong></p>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="VenueId" />

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label class="form-label">Your Name</label>
            <input asp-for="PersonName" class="form-control" />
            <span asp-validation-for="PersonName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Contact Details</label>
            <input asp-for="ContactDetails" class="form-control" />
            <span asp-validation-for="ContactDetails" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Event Type</label>
            <select asp-for="EventTypeId" class="form-select" required asp-items="@(new SelectList(ViewBag.EventTypes, "EventTypeId", "Name"))">
                <option value="">-- Select Event Type --</option>
            </select>
            <span asp-validation-for="EventTypeId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Booking Date</label>
            <input asp-for="BookingDate" type="date" class="form-control" />
            <span asp-validation-for="BookingDate" class="text-danger"></span>
        </div>

        <button class="btn btn-primary">Submit Booking</button>
        <a asp-controller="Venue" asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
