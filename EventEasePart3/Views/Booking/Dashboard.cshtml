@model IEnumerable<EventEasePart3.Models.Booking>

@{
    ViewData["Title"] = "Bookings Dashboard";
}

<h2 class="mb-4">Consolidated Bookings Dashboard</h2>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card stat-card p-3">
            <p>Total Bookings</p>
            <h2>@ViewBag.TotalBookings</h2>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card stat-card p-3">
            <p>Pending</p>
            <h2>@ViewBag.PendingBookings</h2>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card stat-card p-3">
            <p>Approved</p>
            <h2>@ViewBag.ApprovedBookings</h2>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card stat-card p-3">
            <p>Denied</p>
            <h2>@ViewBag.DeniedBookings</h2>
        </div>
    </div>
</div>

<form method="get" class="mb-4">
    <!-- Search Panel -->
    <div class="card app-card p-3 mb-3">
        <h5 class="card-title text-primary mb-3">🔍 Search Bookings</h5>
        <div class="row g-3 align-items-end">
            <div class="col-md-9">
                <label class="form-label">Search Keyword</label>
                <input name="search"
                       value="@ViewBag.Search"
                       class="form-control"
                       placeholder="Search by customer, contact details, venue, event type..." />
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100">Search</button>
            </div>
        </div>
    </div>

    <!-- Filtering Panel -->
    <div class="card app-card p-3">
        <h5 class="card-title text-success mb-3">⚡ Filtering Options</h5>
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Status</label>
                <select name="status" class="form-control">
                    <option value="">All statuses</option>
                    <option value="Pending" selected="@(ViewBag.Status == "Pending")">Pending</option>
                    <option value="Approved" selected="@(ViewBag.Status == "Approved")">Approved</option>
                    <option value="Denied" selected="@(ViewBag.Status == "Denied")">Denied</option>
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Event Type</label>
                <select name="eventTypeId" class="form-control">
                    <option value="">All types</option>
                    @foreach (var et in ViewBag.EventTypes)
                    {
                        <option value="@et.EventTypeId" selected="@(ViewBag.EventTypeId == et.EventTypeId)">@et.Name</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Venue</label>
                <select name="venueId" class="form-control">
                    <option value="">All venues</option>
                    @foreach (var v in ViewBag.Venues)
                    {
                        <option value="@v.VenueId" selected="@(ViewBag.VenueId == v.VenueId)">@v.VenueName</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Venue Availability</label>
                <select name="venueAvailable" class="form-control">
                    <option value="">All</option>
                    <option value="true" selected="@(ViewBag.VenueAvailable == true)">Available Only</option>
                    <option value="false" selected="@(ViewBag.VenueAvailable == false)">Unavailable Only</option>
                </select>
            </div>

            <div class="col-md-5">
                <label class="form-label">Start Date</label>
                <input type="date" name="startDate" value="@ViewBag.StartDate" class="form-control" />
            </div>

            <div class="col-md-5">
                <label class="form-label">End Date</label>
                <input type="date" name="endDate" value="@ViewBag.EndDate" class="form-control" />
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-success w-100">Filter</button>
            </div>
        </div>
    </div>
</form>

<div class="card app-card p-3">
    <table class="table table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Booking ID</th>
                <th>Customer</th>
                <th>Contact</th>
                <th>Venue</th>
                <th>Event Type</th>
                <th>Booking Date</th>
                <th>Booking Status</th>
                <th>Event</th>
                <th>Event Status</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var booking in Model)
            {
                <tr>
                    <td>@booking.BookingId</td>
                    <td>@booking.PersonName</td>
                    <td>@booking.ContactDetails</td>
                    <td>@booking.Venue?.VenueName</td>
                    <td>@(booking.EventType?.Name ?? "N/A")</td>
                    <td>@booking.BookingDate.ToString("yyyy-MM-dd")</td>
                    <td>
                        <span class="badge @(booking.Status == "Approved" ? "bg-success" : booking.Status == "Denied" ? "bg-danger" : "bg-warning text-dark")">
                            @booking.Status
                        </span>
                    </td>
                    <td>@(booking.Event?.EventName ?? "Not created")</td>
                    <td>
                        @if (booking.Event != null)
                        {
                            <span class="badge @(booking.Event.Status == "Approved" ? "bg-success" : booking.Event.Status == "Denied" ? "bg-danger" : "bg-info")">
                                @booking.Event.Status
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">Waiting</span>
                        }
                    </td>
                    <td>
                        @if (booking.Status == "Pending")
                        {
                            <form asp-action="Approve" asp-route-id="@booking.BookingId" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-success btn-sm">Approve</button>
                            </form>

                            <form asp-action="Deny" asp-route-id="@booking.BookingId" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-danger btn-sm">Deny</button>
                            </form>
                        }
                        else
                        {
                            <span class="text-muted">No actions</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
