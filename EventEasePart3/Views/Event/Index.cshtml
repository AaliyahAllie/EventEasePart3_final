@model IEnumerable<EventEasePart3.Models.Event>

@{
    ViewData["Title"] = "Events";
}

<h2 class="mb-4">Event Dashboard</h2>

<form method="get" class="mb-4">
    <!-- Search Panel -->
    <div class="card app-card p-3 mb-3">
        <h5 class="card-title text-primary mb-3">🔍 Search Events</h5>
        <div class="row g-3 align-items-end">
            <div class="col-md-9">
                <label class="form-label">Search Keyword</label>
                <input name="search"
                       value="@ViewBag.Search"
                       class="form-control"
                       placeholder="Search by event name, customer, venue, event type..." />
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100">Search</button>
            </div>
        </div>
    </div>

    <!-- Filtering Panel -->
    <div class="card app-card p-3">
        <h5 class="card-title text-success mb-3">⚡ Filtering Options</h5>
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Status</label>
                <select name="status" class="form-control">
                    <option value="">All statuses</option>
                    <option value="Pending" selected="@(ViewBag.Status == "Pending")">Pending</option>
                    <option value="Approved" selected="@(ViewBag.Status == "Approved")">Approved</option>
                    <option value="Denied" selected="@(ViewBag.Status == "Denied")">Denied</option>
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Event Type</label>
                <select name="eventTypeId" class="form-control">
                    <option value="">All types</option>
                    @foreach (var et in ViewBag.EventTypes)
                    {
                        <option value="@et.EventTypeId" selected="@(ViewBag.EventTypeId == et.EventTypeId)">@et.Name</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Venue</label>
                <select name="venueId" class="form-control">
                    <option value="">All venues</option>
                    @foreach (var v in ViewBag.Venues)
                    {
                        <option value="@v.VenueId" selected="@(ViewBag.VenueId == v.VenueId)">@v.VenueName</option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Venue Availability</label>
                <select name="venueAvailable" class="form-control">
                    <option value="">All</option>
                    <option value="true" selected="@(ViewBag.VenueAvailable == true)">Available Only</option>
                    <option value="false" selected="@(ViewBag.VenueAvailable == false)">Unavailable Only</option>
                </select>
            </div>

            <div class="col-md-5">
                <label class="form-label">Start Date</label>
                <input type="date" name="startDate" value="@ViewBag.StartDate" class="form-control" />
            </div>

            <div class="col-md-5">
                <label class="form-label">End Date</label>
                <input type="date" name="endDate" value="@ViewBag.EndDate" class="form-control" />
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-success w-100">Filter</button>
            </div>
        </div>
    </div>
</form>

<div class="card app-card p-3">
    <table class="table table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Event</th>
                <th>Customer</th>
                <th>Venue</th>
                <th>Event Type</th>
                <th>Date</th>
                <th>Description</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var ev in Model)
            {
                <tr>
                    <td>@ev.EventName</td>
                    <td>@ev.CustomerName</td>
                    <td>@ev.Venue?.VenueName</td>
                    <td>@(ev.EventType?.Name ?? "N/A")</td>
                    <td>@ev.EventDate.ToString("yyyy-MM-dd")</td>
                    <td>@ev.Description</td>
                    <td>
                        <span class="badge @(ev.Status == "Approved" ? "bg-success" : ev.Status == "Denied" ? "bg-danger" : "bg-warning text-dark")">
                            @ev.Status
                        </span>
                    </td>
                    <td>
                        @if (ev.Status == "Pending")
                        {
                            <form asp-action="Approve" asp-route-id="@ev.EventId" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-success btn-sm">Approve</button>
                            </form>

                            <form asp-action="Deny" asp-route-id="@ev.EventId" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-danger btn-sm">Deny</button>
                            </form>
                        }

                        <form asp-action="Delete" asp-route-id="@ev.EventId" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-outline-danger btn-sm"
                                    onclick="return confirm('Are you sure you want to delete this event?')">
                                Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
